# Service Role (nur Server): u. a. schnelle Registrierungs-Bestätigung per Resend (generateLink).
# Project Settings → API → service_role (niemals im Client verwenden).
SUPABASE_SERVICE_ROLE_KEY=

# Resend (E-Mails: Freigaben, Referenzbedarf, Team-Einladungen, optional Bestätigungslink bei Registrierung)
RESEND_API_KEY=re_hUHJTUkM_GF9ZcUWRe73V1kQC142PahYH
# Optional: Absender mit verifizierter Domain, z. B. "Refstack <team@deine-domain.de>".
# Ohne RESEND_FROM nutzt die App onboarding@resend.dev (nur für Tests / eingeschränkte Empfänger).
RESEND_FROM=onboarding@resend.dev

# E-Mail für "Referenzbedarf melden" (wird an diesen Reference Manager gesendet)
REFERENCE_MANAGER_EMAIL=

# Brandfetch API (Unternehmensdaten: Logo, Website, Branche, HQ, Mitarbeiter)
# Key unter https://brandfetch.com/ anlegen
BRANDFETCH_API_KEY=
# Optional: Client-ID für die Brand-Search API (Autocomplete nach Namen). https://developers.brandfetch.com
# Ohne Client-ID wird bei der Suche ein Domain-Fallback genutzt (weniger Treffer).
BRANDFETCH_CLIENT_ID=

# Rollen-Umschaltung für die Oberfläche (Profilmenü + Einstellungen → Tab „Entwicklung“): standardmäßig AN,
# außer VERCEL_ENV=production oder NEXT_PUBLIC_DEV_ROLE_SWITCHER=false (für echtes Produktions-Hosting).
# NEXT_PUBLIC_DEV_ROLE_SWITCHER=false

# OpenAI API (Magic Import: Referenzdaten aus PDF/PPTX extrahieren)
OPENAI_API_KEY=
